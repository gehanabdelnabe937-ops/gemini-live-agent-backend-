async def compare(req: CompareRequest):
    if not GEMINI_API_KEY:
        raise HTTPException(status_code=500, detail="GEMINI_API_KEY not configured")
    start = time.time()
    prompt = f"""Compare these two screenshots.
Task: {req.task}

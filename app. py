@app.post("/voice-command")
async def voice_command(req: VoiceRequest):
    if not GEMINI_API_KEY:
        return {"success": True, "result": {
            "interpreted_task": req.text,
            "action_type": "analyze",
            "parameters": {},
            "confirmation_message": "Processing: " + req.text,
            "requires_screenshot": True
        }}
    prompt = f"""Interpret this voice command: "{req.text}"
Return ONLY this JSON:
{{
  "interpreted_task": "What the user wants",
  "action_type": "analyze/click/type/scroll/navigate/extract/compare",
  "parameters": {{}},
  "confirmation_message": "I will do X for you",
  "requires_screenshot": true
}}
Return ONLY valid JSON."""
    payload = {
        "contents": [{"parts": [{"text": prompt}]}],
        "generationConfig": {"temperature": 0.1, "maxOutputTokens": 512}
    }
    try:
        async with httpx.AsyncClient(timeout=15) as client:
            res = await client.post(GEMINI_URL, json=payload)
            data = res.json()
            text = data["candidates"][0]["content"]["parts"][0]["text"]
            parsed = parse_json(text)
            return {"success": True, "result": parsed}
    except:
        return {"success": True, "result": {
            "interpreted_task": req.text,
            "action_type": "analyze",
            "parameters": {},
            "confirmation_message": "Processing: " + req.text,
            "requires_screenshot": True
        }}

from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
import httpx
import os
import json
import re
import time

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

GEMINI_API_KEY = os.environ.get("GEMINI_API_KEY", "")
GEMINI_URL = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={GEMINI_API_KEY}"

class AnalyzeRequest(BaseModel):
    image_base64: str
    task: str = "Analyze this screen and describe all visible UI elements"
    url: str = ""

class CompareRequest(BaseModel):
    image1_base64: str
    image2_base64: str
    task: str = "Compare these two pages and list the differences"

class VoiceRequest(BaseModel):
    text: str
    task: str = ""

def parse_json(text: str) -> dict:
    text = text.strip()
    text = re.sub(r"```json\s*", "", text)
    text = re.sub(r"```\s*", "", text).strip()
    try:
        return json.loads(text)
    except:
        return {
            "summary": text[:500],
            "page_type": "unknown",
            "ui_elements": {"buttons": 0, "inputs": 0, "text_elements": 0, "links": 0},
            "detected_elements": [],
            "recommended_actions": [],
            "extracted_text": text,
            "confidence": 0.5,
            "analysis_notes": "Raw text response"
        }

@app.get("/")
def root():
    return {
        "status": "Gemini Live Agent v4 — Online",
        "gemini_configured": bool(GEMINI_API_KEY)
    }

@app.get("/health")
def health():
    return {"status": "ok", "timestamp": time.time()}

@app.post("/analyze")
async def analyze(req: AnalyzeRequest):
    if not GEMINI_API_KEY:
        raise HTTPException(status_code=500, detail="GEMINI_API_KEY not configured")
    start = time.time()
    prompt = f"""You are an expert UI/UX analyzer.
Task: {req.task}
{"URL: " + req.url if req.url else ""}
Analyze the screenshot and return ONLY this JSON:
{{
  "summary": "Brief description",
  "page_type": "login/dashboard/ecommerce/etc",
  "ui_elements": {{"buttons": 0, "inputs": 0, "text_elements": 0, "links": 0}},
  "detected_elements": [{{"type": "button/input/link/text", "label": "text", "position": "top/center/bottom"}}],
  "recommended_actions": [{{"action": "click/type/scroll", "target": "element", "reason": "why"}}],
  "extracted_text": "All visible text",
  "confidence": 0.95,
  "analysis_notes": "observations"
}}
Return ONLY valid JSON."""
    parts = [
        {"text": prompt},
        {"inline_data": {"mime_type": "image/jpeg", "data": req.image_base64}}
    ]
    payload = {
        "contents": [{"parts": parts}],
        "generationConfig": {"temperature": 0.1, "maxOutputTokens": 2048}
    }
    async with httpx.AsyncClient(timeout=30) as client:
        res = await client.post(GEMINI_URL, json=payload)
        if res.status_code != 200:
            raise HTTPException(status_code=res.status_code, detail=res.text)
        data = res.json()
        text = data["candidates"][0]["content"]["parts"][0]["text"]
        parsed = parse_json(text)
        elapsed = round((time.time() - start) * 1000)
        return {"success": True, "result": parsed, "elapsed_ms": elapsed}

